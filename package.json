{
  "name": "listen",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:desktop": "npm run start --workspace @listen/desktop",
    "dev:realtime": "npm run dev --workspace @listen/realtime",
    "dist:desktop": "npm run dist --workspace @listen/desktop"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.21",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
